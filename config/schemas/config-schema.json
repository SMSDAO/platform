{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SMSDAO Platform Config Schema",
  "description": "Validates config.{Dev,Staging,Prod}.json files. Secrets must never appear as values.",
  "type": "object",
  "properties": {
    "_comment":             { "type": "string" },
    "environment":          { "type": "string", "enum": ["Dev", "Staging", "Prod"] },
    "logLevel":             { "type": "string", "enum": ["Debug", "Info", "Warn", "Error"] },
    "dryRunDefault":        { "type": "boolean" },
    "testVerbosity":        { "type": "string", "enum": ["Minimal", "Normal", "Detailed", "Diagnostic"] },
    "testPath":             { "type": "string" },
    "buildOutput":          { "type": "string" },
    "namespace":            { "type": "string" },
    "manifest":             { "type": "string" },
    "deployment":           { "type": "string" },
    "imageTag":             { "type": "string" },
    "vercelEnv":            { "type": "string", "enum": ["production", "preview"] },
    "resourceGroup":        { "type": "string" },
    "appName":              { "type": "string" },
    "awsRegion":            { "type": "string" }
  },
  "required": ["environment"],
  "additionalProperties": true,
  "propertyNames": {
    "not": {
      "pattern": "(password|secret|private.?key|api[_-]?key|token|credential|access.?key)"
    }
  }
}
